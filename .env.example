# SUVI Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# REQUIRED - Google Cloud Project
# ============================================

# Your Google Cloud Project ID (create at https://console.cloud.google.com)
GCP_PROJECT=your-project-id

# Region: asia-south1 (Mumbai) - closest to you
# For global access, Cloud Run automatically handles latency
GCP_LOCATION=asia-south1

# ============================================
# REQUIRED - Authentication
# ============================================

# For local development, download service account key from:
# IAM & Admin > Service Accounts > Keys > Add Key > JSON
# Then set this environment variable:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-project-credentials.json

# Or use gcloud to authenticate:
# gcloud auth application-default login

# ============================================
# REQUIRED - API Keys
# ============================================

# Get from https://console.cloud.google.com/apis/credentials
# Note: For Gemini Live API, you need Vertex AI access
VERTEX_API_KEY=your-vertex-api-key
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# REQUIRED - Security
# ============================================

# Client token for desktop app authentication
# Generate a secure random string for production
SUVI_CLIENT_TOKEN=suvi-hackathon-secret-123

# API key for service-to-service communication
SUVI_API_KEY=your-api-key

# ============================================
# OPTIONAL - Feature Flags
# ============================================

# Enable detailed logging (true/false)
SUVI_DEBUG=false

# Enable analytics (true/false)
SUVI_ANALYTICS=true

# Voice configuration
WAKE_WORD_ENABLED=true
VOICE_INPUT_ENABLED=true

# ============================================
# OPTIONAL - Third-Party Services
# ============================================

# For production, you might add:
# - SendGrid for email (email agent)
# - Slack API for notifications
# - Custom Vector Search endpoint
